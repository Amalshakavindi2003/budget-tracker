{
    "compilerOptions":  {
                            "target":  "ES2020",
                            "module":  "commonjs",
                            "rootDir":  "./src",
                            "outDir":  "./dist",
                            "moduleResolution":  "node",
                            "esModuleInterop":  true,
                            "forceConsistentCasingInFileNames":  true,
                            "strict":  true,
                            "skipLibCheck":  true,
                            "resolveJsonModule":  true,
                            "types":  [
                                          "node"
                                      ],
                            "ignoreDeprecations":  "6.0"
                        },
    "include":  [
                    "src/**/*.ts"
                ],
    "exclude":  [
                    "node_modules",
                    "dist"
                ]
}
